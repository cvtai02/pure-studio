{%- assign collection_obj = collections[section.settings.collection] -%}
<section class="featured-collection section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="carousel" data-carousel>

      <div class="carousel__header" style="display: flex; align-items: flex-end; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
        <div>
          {%- if section.settings.heading != blank -%}
            <h2 class="carousel__heading section-heading" style="margin-bottom: 0;">{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.menu != blank -%}
            {%- assign menu = linklists[section.settings.menu] -%}
            {%- if menu.links.size > 0 -%}
              <nav class="featured-collection__menu" aria-label="{{ menu.title }}">
                {%- for link in menu.links -%}
                  <a href="{{ link.url }}" class="featured-collection__menu-link{% if link.active %} featured-collection__menu-link--active{% endif %}">{{ link.title }}</a>
                {%- endfor -%}
              </nav>
            {%- endif -%}
          {%- endif -%}
        </div>
        {%- if section.settings.show_view_all and collection_obj and collection_obj.products_count > 0 -%}
          <a href="{{ collection_obj.url }}" class="advice-articles__view-all">
            {{ 'general.collection.view_all' | t }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

        <div class="carousel__nav">
          <button class="carousel__btn carousel__btn--prev" data-carousel-prev aria-label="Previous">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="carousel__btn carousel__btn--next" data-carousel-next aria-label="Next">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>


        {%- assign products_to_show = section.settings.products_to_show -%}

        <div class="carousel__track" data-carousel-track>
          {%- if collection_obj and collection_obj.products_count > 0 -%}
            {%- for product in collection_obj.products limit: products_to_show -%}
              <div class="carousel__slide">
                {% render 'product-card', product: product %}
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..products_to_show) -%}
              <div class="carousel__slide">
                {% render 'product-card-placeholder' %}
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>


    </div>
  </section>

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's Trending"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Number of columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "info": "Select a navigation menu to display as links in this section header (e.g. a 'Trending' menu)."    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}

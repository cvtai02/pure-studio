<section class="section-trust-badges" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="trust-badges__grid">
      {%- for block in section.blocks -%}
        <div class="trust-badge" {{ block.shopify_attributes }}>
          <div class="trust-badge__icon">
            {%- case block.settings.icon -%}
              {%- when 'shipping' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="15" height="13"></rect>
                  <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                  <circle cx="5.5" cy="18.5" r="2.5"></circle>
                  <circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 12 11 14 15 10"></polyline>
                </svg>
              {%- when 'heart' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
              {%- when 'return' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="1 4 1 10 7 10"></polyline>
                  <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
                </svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              {%- when 'paw' -%}
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 21c-1.5 0-3.5-2-5-4.5S4 11 5.5 9.5 9 8 10 9s1.5 2 2 2 1-1.5 2-2 2.5-1 4-.5S20 11 19 14s-3.5 4.5-5 4.5V21h-2z"/>
                  <circle cx="7" cy="6" r="2"/>
                  <circle cx="17" cy="6" r="2"/>
                  <circle cx="4.5" cy="11" r="1.5"/>
                  <circle cx="19.5" cy="11" r="1.5"/>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            {%- endcase -%}
          </div>
          <div>
            {%- if block.settings.title != blank -%}
              <p class="trust-badge__title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="trust-badge__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust badges",
  "tag": "section",
  "class": "section-trust-badges",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping truck" },
            { "value": "shield", "label": "Shield / Warranty" },
            { "value": "heart", "label": "Heart" },
            { "value": "return", "label": "Return / Refund" },
            { "value": "star", "label": "Star / Quality" },
            { "value": "paw", "label": "Paw print" },
            { "value": "check", "label": "Checkmark" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "On orders over $50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "shipping",
            "title": "Free Shipping",
            "text": "On orders over $50"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "shield",
            "title": "Satisfaction Guaranteed",
            "text": "30-day money back guarantee"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "paw",
            "title": "Pet Safe Materials",
            "text": "100% safe for your pets"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "heart",
            "title": "24/7 Support",
            "text": "We're here to help"
          }
        }
      ]
    }
  ]
}
{% endschema %}

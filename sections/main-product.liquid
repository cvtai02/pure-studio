<section class="main-product section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="product__breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      {%- if collection -%}
        <span class="product__breadcrumb-sep">/</span>
        <a href="{{ collection.url }}">{{ collection.title }}</a>
      {%- endif -%}
      <span class="product__breadcrumb-sep">/</span>
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <div class="product__wrapper grid grid--2">
      {%- comment -%} Product Media {%- endcomment -%}
      <div class="product__media-wrapper">
        {%- if product.featured_media -%}
          <div class="product__media-main" id="ProductMainMedia-{{ section.id }}">
            {%- if product.media.size > 1 -%}
              <button class="product__media-arrow product__media-arrow--prev" aria-label="Previous image">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <button class="product__media-arrow product__media-arrow--next" aria-label="Next image">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            {%- endif -%}
            <div class="product__slider-track">
              {%- for media in product.media -%}
                <div class="product__slide">
                  <img
                    src="{{ media | image_url: width: 900 }}"
                    alt="{{ media.alt | escape }}"
                    width="900"
                    height="{{ 900 | divided_by: media.aspect_ratio | round }}"
                    {%- if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
                  >
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- if product.media.size > 1 -%}
          <div class="product__thumbnails-slider">
            <button class="product__thumbs-arrow product__thumbs-arrow--prev" aria-label="Previous thumbnails">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="product__media-thumbnails">
              {%- for media in product.media -%}
                <button
                  class="product__thumbnail{% if forloop.first %} product__thumbnail--active{% endif %}"
                  data-media-id="{{ media.id }}"
                  data-media-src="{{ media | image_url: width: 900 }}"
                  data-media-alt="{{ media.alt | escape }}"
                  aria-label="Load image {{ forloop.index }}"
                >
                  <img
                    src="{{ media | image_url: width: 150 }}"
                    alt="{{ media.alt | escape }}"
                    width="150"
                    height="{{ 150 | divided_by: media.aspect_ratio | round }}"
                    loading="lazy"
                  >
                </button>
              {%- endfor -%}
            </div>
            <button class="product__thumbs-arrow product__thumbs-arrow--next" aria-label="Next thumbnails">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Product Info {%- endcomment -%}
      <div class="product__info-wrapper">
        {%- if section.settings.show_vendor and product.vendor -%}
          <p class="product__vendor eyebrow-text">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product__title h2">{{ product.title }}</h1>

        <div class="product__price-box" style="border: 2px solid #ffe066; border-radius: 0.5em; padding: 0.5em 1.2em; margin-bottom: 1em; display: inline-block; box-shadow: 0 2px 8px rgba(255,224,102,0.2);">
          <div class="product__price">
            {%- if product.compare_at_price > product.price -%}
              <span class="product__price--sale">{{ product.price | money }}</span>
              <span class="product__price--compare">{{ product.compare_at_price | money }}</span>
              {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
              <span class="product__badge badge badge--sale">Save {{ savings }}%</span>
            {%- else -%}
              <span class="product__price--regular">{{ product.price | money }}</span>
            {%- endif -%}
            <span class="product__badge badge badge--shipping" style="color: #4caf50; font-weight: 500; margin-left: 0.75em; padding: 0.1em 0.5em; border-radius: 0.3em; font-size: 0.85em; display: inline-flex; align-items: center; gap: 0.3em;">
              <img src="{{ 'shipping-truck.svg' | asset_url }}" alt="Shipping Truck" width="16" height="16" style="vertical-align: middle; display: inline-block;" loading="lazy" />
              <span style="font-size:0.92em;">Free Shipping</span>
            </span>
          </div>
        </div>

        {%- if product.available -%}
          {% form 'product', product, class: 'product__form' %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

            {%- for option in product.options_with_values -%}
              <div class="product__option">
                <label class="product__option-label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                  {{ option.name }}
                </label>
                {%- if forloop.first -%}
                  <div class="product__option-rectangles">
                    {%- for value in option.values -%}
                      {%- assign variant_image = null -%}
                      {%- for variant in product.variants -%}
                        {%- if variant.options[0] == value and variant.featured_image -%}
                          {%- assign variant_image = variant.featured_image | image_url: width: 96 -%}
                        {%- endif -%}
                      {%- endfor -%}
                      <button type="button"
                        class="product__option-rectangle{% if option.selected_value == value %} product__option-rectangle--active{% endif %}"
                        data-option-index="{{ forloop.index0 }}"
                        data-option-value="{{ value | escape }}"
                        aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                        onclick="var input=this.closest('form').querySelector('[name=\'options[{{ option.name | escape }}]\']'); input.value='{{ value | escape }}'; input.dispatchEvent(new Event('change', {bubbles:true}));"
                      >
                        {%- if variant_image -%}
                          <img src="{{ variant_image }}" alt="{{ value }}" />
                        {%- endif -%}
                        <span>{{ value }}</span>
                      </button>
                    {%- endfor -%}
                    <input type="hidden" name="options[{{ option.name | escape }}]" value="{{ option.selected_value | escape }}">
                  </div>
                {%- else -%}
                  <select
                    id="Option-{{ section.id }}-{{ forloop.index0 }}"
                    class="product__option-select field__input"
                    name="options[{{ option.name | escape }}]"
                  >
                    {%- for value in option.values -%}
                      <option
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}selected{% endif %}
                      >
                        {{ value }}
                      </option>
                    {%- endfor -%}
                  </select>
                {%- endif -%}
              </div>
            {%- endfor -%}

            <div class="product__quantity">
              <label class="product__quantity-label" for="Quantity-{{ section.id }}">
                {{ 'products.product.quantity' | t }}
              </label>
              <div class="product__quantity-selector">
                <button type="button" class="product__quantity-btn" data-action="decrease" aria-label="Decrease quantity">−</button>
                <input
                  type="number"
                  id="Quantity-{{ section.id }}"
                  class="product__quantity-input field__input"
                  name="quantity"
                  value="1"
                  min="1"
                >
                <button type="button" class="product__quantity-btn" data-action="increase" aria-label="Increase quantity">+</button>
              </div>
            </div>

            <button type="submit" class="button button--primary product__submit" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
              {%- if product.selected_or_first_available_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
            <div class="safe-checkout-box">
              <div class="safe-checkout-title">Guaranteed Safe Checkout</div>
              <div class="safe-checkout-icons">
                <img src="https://upload.wikimedia.org/wikipedia/commons/0/04/Visa.svg" alt="Visa" title="Visa" />
                <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" alt="Mastercard" title="Mastercard" />
                <img src="https://upload.wikimedia.org/wikipedia/commons/3/30/American_Express_logo_%282018%29.svg" alt="American Express" title="American Express" />
                <img src="https://upload.wikimedia.org/wikipedia/commons/5/5a/Discover_Card_logo.svg" alt="Discover" title="Discover" />
                <img src="https://upload.wikimedia.org/wikipedia/commons/4/41/Stripe_Logo%2C_revised_2016.svg" alt="Stripe" title="Stripe" />
                <img src="https://upload.wikimedia.org/wikipedia/commons/3/39/PayPal_logo.svg" alt="PayPal" title="PayPal" />
                <img src="https://upload.wikimedia.org/wikipedia/commons/2/2b/Ssl_certificate_logo.svg" alt="SSL Secure" title="SSL Secure" />
              </div>
            </div>
          {% endform %}
        {%- else -%}
          <button class="button button--primary product__submit" disabled>
            {{ 'products.product.sold_out' | t }}
          </button>
        {%- endif -%}
      </div>
    </div>

    {%- if product.description != blank -%}
      <div class="product__description-full">
        <h2 class="product__description-title">Description</h2>
        <div class="product__description-content rte">
          {{ product.description }}
        </div>
      </div>
    {%- endif -%}
</div>
<!-- Cart Modal -->
<div class="cart-modal-overlay" id="CartModalOverlay">
  <div class="cart-modal">
    <div class="cart-modal-header">Your Cart</div>
    <div class="cart-modal-list" id="CartModalList">
      <!-- Items will be injected here -->
    </div>
    <div class="cart-modal-footer">
      <div style="flex:1;display:flex;align-items:center;font-weight:600;font-size:1.1em;">
        Total: <span id="CartModalTotal" style="margin-left:0.5em;color:#ff3cac;"></span>
      </div>
      <a href="/checkout" class="cart-modal-checkout">Checkout</a>
    </div>
  </div>
</div>
<script>
  function showCartModal(items, total) {
    var overlay = document.getElementById('CartModalOverlay');
    var list = document.getElementById('CartModalList');
    var totalEl = document.getElementById('CartModalTotal');
    list.innerHTML = '';
    if (!items || !items.length) {
      list.innerHTML = '<div style="text-align:center;color:#888;">Your cart is empty.</div>';
      if (totalEl) totalEl.textContent = '0';
    } else {
      items.forEach(function(item) {
        var div = document.createElement('div');
        div.className = 'cart-modal-item';
        div.innerHTML =
          '<img src="' + (item.image || '') + '" alt="' + (item.title || '') + '" />' +
          '<div class="cart-modal-item-info">' +
            '<div class="cart-modal-item-title">' + item.title + '</div>' +
            '<div class="cart-modal-item-qty">Qty: ' + item.quantity + '</div>' +
          '</div>' +
          '<div class="cart-modal-item-price">' + item.price + '</div>';
        list.appendChild(div);
      });
      if (totalEl) totalEl.textContent = total;
    }
    overlay.classList.add('active');
    // Helper to close modal and re-enable add to cart
    function closeCartModal() {
      overlay.classList.remove('active');
      var form = document.querySelector('.product__form');
      var addBtn = form ? form.querySelector('.product__submit') : null;
      if (addBtn) addBtn.disabled = false;
    }
    // Allow closing modal by clicking overlay (not modal)
    overlay.onclick = function(e) {
      if (e.target === overlay) closeCartModal();
    };
    // Also close on Escape key
    document.onkeydown = function(e) {
      if (e.key === 'Escape') closeCartModal();
    };
  }
  // Intercept add to cart
  document.addEventListener('DOMContentLoaded', function() {
    var form = document.querySelector('.product__form');
    var addBtn = form ? form.querySelector('.product__submit') : null;
    if (form && addBtn) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        addBtn.disabled = true;
        var data = new FormData(form);
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: data
        })
        .then(function(res) { return res.json(); })
        .then(function() {
          return fetch('/cart.js', { headers: { 'Accept': 'application/json' }});
        })
        .then(function(res) { return res.json(); })
        .then(function(cart) {
          var currency = cart.currency || 'USD';
          var items = (cart.items || []).map(function(item) {
            var price = Shopify.formatMoney ? Shopify.formatMoney(item.price, window.shopCurrencyFormat || "${{amount}}") : (item.price/100).toFixed(2);
            return {
              image: item.image ? item.image.replace(/_(\d+x\d+|large|medium|small|compact|grande|original)\./, '_100x100.') : '',
              title: item.product_title + (item.variant_title && item.variant_title !== 'Default Title' ? ' - ' + item.variant_title : ''),
              quantity: item.quantity,
              price: price + ' ' + currency
            };
          });
          var total = (Shopify.formatMoney ? Shopify.formatMoney(cart.total_price, window.shopCurrencyFormat || "${{amount}}") : (cart.total_price/100).toFixed(2)) + ' ' + currency;
          showCartModal(items, total);
        });
      });
      // Re-enable add to cart when modal closes
      var overlay = document.getElementById('CartModalOverlay');
      if (overlay) {
        overlay.addEventListener('transitionend', function() {
          if (!overlay.classList.contains('active')) addBtn.disabled = false;
        });
        // Also re-enable on click outside or Escape
        overlay.onclick = function(e) {
          if (e.target === overlay) {
            overlay.classList.remove('active');
            addBtn.disabled = false;
          }
        };
        document.onkeydown = function(e) {
          if (e.key === 'Escape') {
            overlay.classList.remove('active');
            addBtn.disabled = false;
          }
        };
      }
    }
  });
</script>
</section>

{% schema %}
{
  "name": "Product information",
  "tag": "section",
  "class": "section-main-product__wrapper",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    }
  ]
}
{% endschema %}

<section class="main-product section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="product__breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      {%- if collection -%}
        <span class="product__breadcrumb-sep">/</span>
        <a href="{{ collection.url }}">{{ collection.title }}</a>
      {%- endif -%}
      <span class="product__breadcrumb-sep">/</span>
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <div class="product__wrapper grid grid--2">
      {%- comment -%} Product Media {%- endcomment -%}
      <div class="product__media-wrapper">
        {%- if product.featured_media -%}
          <div class="product__media-main" id="ProductMainMedia-{{ section.id }}">
            {%- if product.media.size > 1 -%}
              <button class="product__media-arrow product__media-arrow--prev" aria-label="Previous image">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <button class="product__media-arrow product__media-arrow--next" aria-label="Next image">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            {%- endif -%}
            <div class="product__slider-track">
              {%- for media in product.media -%}
                <div class="product__slide">
                  <img
                    src="{{ media | image_url: width: 900 }}"
                    alt="{{ media.alt | escape }}"
                    width="900"
                    height="{{ 900 | divided_by: media.aspect_ratio | round }}"
                    {%- if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
                  >
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- if product.media.size > 1 -%}
          <div class="product__thumbnails-slider">
            <button class="product__thumbs-arrow product__thumbs-arrow--prev" aria-label="Previous thumbnails">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="product__media-thumbnails">
              {%- for media in product.media -%}
                <button
                  class="product__thumbnail{% if forloop.first %} product__thumbnail--active{% endif %}"
                  data-media-id="{{ media.id }}"
                  data-media-src="{{ media | image_url: width: 900 }}"
                  data-media-alt="{{ media.alt | escape }}"
                  aria-label="Load image {{ forloop.index }}"
                >
                  <img
                    src="{{ media | image_url: width: 150 }}"
                    alt="{{ media.alt | escape }}"
                    width="150"
                    height="{{ 150 | divided_by: media.aspect_ratio | round }}"
                    loading="lazy"
                  >
                </button>
              {%- endfor -%}
            </div>
            <button class="product__thumbs-arrow product__thumbs-arrow--next" aria-label="Next thumbnails">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Product Info {%- endcomment -%}
      <div class="product__info-wrapper">
        {%- if section.settings.show_vendor and product.vendor -%}
          <p class="product__vendor eyebrow-text">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product__title h2">{{ product.title }}</h1>

        <div class="product__price-box" style="border: 2px solid #ffe066; border-radius: 0.5em; padding: 0.5em 1.2em 0.5em 1.2em; margin-bottom: 1em; display: inline-block; box-shadow: 0 2px 8px rgba(255,224,102,0.2);">
          <div class="product__price">
            {%- if product.compare_at_price > product.price -%}
              <span class="product__price--sale">{{ product.price | money }}</span>
              <span class="product__price--compare">{{ product.compare_at_price | money }}</span>
              {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
              <span class="product__badge badge badge--sale">Save {{ savings }}%</span>
            {%- else -%}
              <span class="product__price--regular">{{ product.price | money }}</span>
            {%- endif -%}
            <span class="product__badge badge badge--shipping" style="color: #4caf50; font-weight: 500; margin-left: 0.75em; padding: 0.1em 0.5em; border-radius: 0.3em; font-size: 0.85em; display: inline-flex; align-items: center; gap: 0.3em;">
              <img src="{{ 'shipping-truck.svg' | asset_url }}" alt="Shipping Truck" width="16" height="16" style="vertical-align: middle; display: inline-block;" loading="lazy" />
              <span style="font-size:0.92em;">Free Shipping</span>
            </span>
          </div>
        </div>

        {%- if product.available -%}
          {% form 'product', product, class: 'product__form' %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

            {%- for option in product.options_with_values -%}
              <div class="product__option">
                <label class="product__option-label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                  {{ option.name }}
                </label>
                <select
                  id="Option-{{ section.id }}-{{ forloop.index0 }}"
                  class="product__option-select field__input"
                  name="options[{{ option.name | escape }}]"
                >
                  {%- for value in option.values -%}
                    <option
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}selected{% endif %}
                    >
                      {{ value }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}

            <div class="product__quantity">
              <label class="product__quantity-label" for="Quantity-{{ section.id }}">
                {{ 'products.product.quantity' | t }}
              </label>
              <div class="product__quantity-selector">
                <button type="button" class="product__quantity-btn" data-action="decrease" aria-label="Decrease quantity">−</button>
                <input
                  type="number"
                  id="Quantity-{{ section.id }}"
                  class="product__quantity-input field__input"
                  name="quantity"
                  value="1"
                  min="1"
                >
                <button type="button" class="product__quantity-btn" data-action="increase" aria-label="Increase quantity">+</button>
              </div>
            </div>

            <button type="submit" class="button button--primary product__submit" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
              {%- if product.selected_or_first_available_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
          {% endform %}
        {%- else -%}
          <button class="button button--primary product__submit" disabled>
            {{ 'products.product.sold_out' | t }}
          </button>
        {%- endif -%}
      </div>
    </div>

    {%- if product.description != blank -%}
      <div class="product__description-full">
        <h2 class="product__description-title">Description</h2>
        <div class="product__description-content rte">
          {{ product.description }}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product information",
  "tag": "section",
  "class": "section-main-product__wrapper",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    }
  ]
}
{% endschema %}

<section class="section-category-explorer" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="carousel" data-carousel>
      <div class="carousel__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="carousel__heading section-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        <div class="carousel__nav">
          <button class="carousel__btn carousel__btn--prev" data-carousel-prev aria-label="Previous">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="carousel__btn carousel__btn--next" data-carousel-next aria-label="Next">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="category-explorer__track" data-carousel-track>
        {%- for block in section.blocks -%}
          <div class="category-explorer__item" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="category-explorer__link">
              <div class="category-explorer__image">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 400 }}"
                    alt="{{ block.settings.label | escape }}"
                    width="400"
                    height="400"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'product-card__placeholder' }}
                {%- endif -%}
              </div>
              <span class="category-explorer__label">{{ block.settings.label }}</span>
            </a>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category explorer",
  "tag": "section",
  "class": "section-category-explorer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Categories"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category explorer",
      "blocks": [
        { "type": "category", "settings": { "label": "New Releases" } },
        { "type": "category", "settings": { "label": "Best Sellers" } },
        { "type": "category", "settings": { "label": "Spring Gear" } },
        { "type": "category", "settings": { "label": "Accessories" } },
        { "type": "category", "settings": { "label": "Apparel" } },
        { "type": "category", "settings": { "label": "Sale" } }
      ]
    }
  ]
}
{% endschema %}

<section class="feature-banner" data-section-id="{{ section.id }}" style="min-height: {{ section.settings.min_height }}px;">
  {%- if section.settings.image != blank -%}
    <img
      class="feature-banner__bg"
      src="{{ section.settings.image | image_url: width: 1920 }}"
      alt="{{ section.settings.heading | escape }}"
      width="1920"
      height="{{ 1920 | divided_by: section.settings.image.aspect_ratio | round }}"
      loading="lazy"
    >
  {%- else -%}
    <div class="feature-banner__bg-placeholder"></div>
  {%- endif -%}

  <div class="feature-banner__overlay"></div>

  <div class="feature-banner__content page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="feature-banner__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="h1">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="feature-banner__text">{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="button button--white">
        {{ section.settings.button_label | escape }}
        <svg class="button__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Feature banner",
  "tag": "section",
  "class": "section-feature-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Featured Blog"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "About the Collection"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Lighter, stronger, faster. This collection represents the forefront of innovation, designed to take you further."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Feature banner"
    }
  ]
}
{% endschema %}

<section class="split-feature{% if section.settings.reverse_layout %} split-feature--reverse{% endif %}" data-section-id="{{ section.id }}">
  <div class="split-feature__media">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ section.settings.heading | escape }}"
        width="1200"
        height="{{ 1200 | divided_by: section.settings.image.aspect_ratio | round }}"
        loading="lazy"
      >
    {%- else -%}
      <div class="split-feature__media-placeholder">
        {{ 'lifestyle-2' | placeholder_svg_tag: 'product-card__placeholder' }}
      </div>
    {%- endif -%}
  </div>

  <div class="split-feature__content split-feature__content--{{ section.settings.content_style }}">
    {%- if section.settings.eyebrow != blank -%}
      <p class="split-feature__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="split-feature__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="split-feature__text">{{ section.settings.text }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="split-feature__list list-unstyled">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature_point' -%}
            <li class="split-feature__list-item" {{ block.shopify_attributes }}>
              <span class="split-feature__list-icon" aria-hidden="true">
                {%- if block.settings.icon == 'checkmark' -%}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- elsif block.settings.icon == 'shield' -%}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- elsif block.settings.icon == 'star' -%}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- else -%}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {%- endif -%}
              </span>
              <span class="split-feature__list-text">{{ block.settings.text }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      {%- assign stats = section.blocks | where: 'type', 'stat' -%}
      {%- if stats.size > 0 -%}
        <div class="split-feature__stats">
          {%- for block in stats -%}
            <div class="split-feature__stat" {{ block.shopify_attributes }}>
              <span class="split-feature__stat-value">{{ block.settings.value }}</span>
              <span class="split-feature__stat-label">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="button {% if section.settings.content_style == 'dark' %}button--white{% else %}button--primary{% endif %}" style="margin-top: 2rem;">
        {{ section.settings.button_label | escape }}
        <svg class="button__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Split feature",
  "tag": "section",
  "class": "section-split-feature",
  "blocks": [
    {
      "type": "feature_point",
      "name": "Feature point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Crash-tested and certified safe"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "checkmark", "label": "Checkmark" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" }
          ],
          "default": "checkmark"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Stat highlight",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "500K+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Pets Protected"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Featured Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Collection"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Lighter, stronger, faster. This collection represents the forefront of innovation, designed to take you further."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "content_style",
      "label": "Content style",
      "options": [
        { "value": "dark", "label": "Dark background" },
        { "value": "light", "label": "Light background" }
      ],
      "default": "dark"
    },
    {
      "type": "checkbox",
      "id": "reverse_layout",
      "label": "Reverse layout (image right)",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Split feature"
    }
  ]
}
{% endschema %}

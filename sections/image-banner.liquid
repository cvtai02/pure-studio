<section class="image-banner" data-section-id="{{ section.id }}">
  <div class="image-banner__wrapper" style="min-height: {{ section.settings.banner_height }}px;">
    {%- if section.settings.video_url != blank -%}
      <video
        class="image-banner__image"
        autoplay
        muted
        loop
        playsinline
        poster="{%- if section.settings.image != blank -%}{{ section.settings.image | image_url: width: 1920 }}{%- endif -%}"
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      <img
        class="image-banner__image"
        src="{{ section.settings.image | image_url: width: 1920 }}"
        alt="{{ section.settings.image.alt | escape }}"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.image.aspect_ratio | round }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <div class="image-banner__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'image-banner__placeholder-svg' }}
      </div>
    {%- endif -%}

    <div class="image-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>

    <div class="image-banner__content page-width">
      <div class="image-banner__text-wrapper text-{{ section.settings.text_alignment }}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="image-banner__eyebrow" style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: rgba(255,255,255,0.8); margin-bottom: 1rem;">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h1 class="image-banner__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="image-banner__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="button button--white button--large image-banner__button">
            {{ section.settings.button_label | escape }}
            <svg class="button__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image banner",
  "tag": "section",
  "class": "section-image-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Optional. Will override the image if set."
    },
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner height",
      "options": [
        { "value": "450", "label": "Small (450px)" },
        { "value": "600", "label": "Medium (600px)" },
        { "value": "750", "label": "Large (750px)" },
        { "value": "100vh", "label": "Full screen" }
      ],
      "default": "100vh"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "unit": "%",
      "default": 40
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Small text above the heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beyond Yesterday's Limits"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Performance gear designed for the adventures that push you further."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ]
}
{% endschema %}

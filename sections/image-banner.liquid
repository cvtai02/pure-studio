<section class="image-banner" data-section-id="{{ section.id }}">
  <div class="image-banner__wrapper" style="min-height: {{ section.settings.banner_height }}px;">
    {%- if section.settings.image != blank -%}
      <img
        class="image-banner__image"
        src="{{ section.settings.image | image_url: width: 1920 }}"
        alt="{{ section.settings.image.alt | escape }}"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.image.aspect_ratio | round }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <div class="image-banner__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'image-banner__placeholder-svg' }}
      </div>
    {%- endif -%}

    <div class="image-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>

    <div class="image-banner__content page-width">
      <div class="image-banner__text-wrapper text-{{ section.settings.text_alignment }}">
        {%- if section.settings.heading != blank -%}
          <h1 class="image-banner__heading h0">{{ section.settings.heading }}</h1>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="image-banner__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="button button--primary image-banner__button">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image banner",
  "tag": "section",
  "class": "section-image-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 550
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "unit": "%",
      "default": 40
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image banner"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Give customers details about the banner image or content on the template."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ]
}
{% endschema %}

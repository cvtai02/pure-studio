<section class="main-collection section-{{ section.id }}" data-section-id="{{ section.id }}">
  {%- if collection.image -%}
    <div class="collection__banner">
      <img
        class="collection__banner-image"
        src="{{ collection.image | image_url: width: 1920 }}"
        alt="{{ collection.image.alt | escape }}"
        width="1920"
        height="{{ 1920 | divided_by: collection.image.aspect_ratio | round }}"
        loading="eager"
      >
      <div class="collection__banner-overlay"></div>
      <div class="collection__banner-content page-width">
        <h1 class="collection__banner-heading h1">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <p class="collection__banner-desc">{{ collection.description | strip_html | truncatewords: 30 }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- else -%}
    <div class="page-width">
      <h1 class="main-collection__heading section-heading">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="main-collection__description rte">{{ collection.description }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="page-width">
    <div class="collection__toolbar">
      <p class="collection__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</p>
    </div>

    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="main-collection__grid grid grid--{{ section.settings.columns }}">
        {%- for product in collection.products -%}
          <div class="grid__item">
            {% render 'product-card', product: product %}
          </div>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        {% render 'pagination', paginate: paginate %}
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "tag": "section",
  "class": "section-main-collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Number of columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    }
  ]
}
{% endschema %}

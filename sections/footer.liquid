<footer class="footer" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="footer__grid">
      {%- for block in section.blocks -%}
        <div class="footer__block" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'menu' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer__menu list-unstyled" role="list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- when 'text' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              <div class="footer__text rte">{{ block.settings.text }}</div>

            {%- when 'social' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {% render 'social-icons' %}

            {%- when 'newsletter' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="footer__text" style="margin-bottom: 1rem;">{{ block.settings.text }}</p>
              {%- endif -%}
              {% form 'customer', class: 'footer__newsletter-form' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div style="display:flex; gap:0.5rem;">
                  <input
                    type="email"
                    name="contact[email]"
                    placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
                    required
                    autocomplete="email"
                    aria-label="{{ 'general.newsletter.email_placeholder' | t }}"
                    class="field__input"
                    style="background:transparent; border-color:rgba(255,255,255,0.3); color:#fff; padding:0.625rem 0.875rem; font-size:0.875rem;"
                  >
                  <button type="submit" class="button" style="background:#fff; color:#1a1a1a; border-color:#fff; padding:0.625rem 1.25rem; font-size:0.75rem;">
                    {{ 'general.newsletter.submit' | t }}
                  </button>
                </div>
              {% endform %}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <div class="footer__copyright">
        <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'general.footer.powered_by' | t }}</small>
      </div>
      <div class="footer__payment">
        {%- unless shop.enabled_payment_types == empty -%}
          <ul class="footer__payment-list list-unstyled" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="footer__payment-item">
                {{ type | payment_type_svg_tag: class: 'icon icon-payment' }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endunless -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "About us"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share store details, promotions, or brand content with your customers.</p>"
        }
      ]
    },
    {
      "type": "social",
      "name": "Social media",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Follow Us"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Stay Connected"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Subscribe for updates on new gear and exclusive deals."
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "menu",
        "settings": {
          "heading": "Learn More"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Support"
        }
      },
      {
        "type": "social",
        "settings": {
          "heading": "Follow Us"
        }
      },
      {
        "type": "newsletter",
        "settings": {
          "heading": "Stay Connected"
        }
      }
    ]
  }
}
{% endschema %}

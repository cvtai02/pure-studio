<footer class="footer" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="footer__grid">
      {%- for block in section.blocks -%}
        <div class="footer__block{% if forloop.first %} footer__block--brand{% endif %}" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'menu' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer__menu list-unstyled" role="list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- when 'text' -%}
              {%- if forloop.first -%}
                {%- comment -%} Brand column {%- endcomment -%}
                <a href="/" class="footer__brand-logo" aria-label="{{ shop.name }}">
                  <svg class="footer__logo-paw" width="32" height="32" viewBox="0 0 100 100" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <ellipse cx="20" cy="28" rx="10" ry="14"/>
                    <ellipse cx="42" cy="16" rx="10" ry="14"/>
                    <ellipse cx="64" cy="16" rx="10" ry="14"/>
                    <ellipse cx="82" cy="28" rx="10" ry="14"/>
                    <path d="M50 42 C28 42 14 58 18 72 C22 86 36 92 50 92 C64 92 78 86 82 72 C86 58 72 42 50 42Z"/>
                  </svg>
                  <span class="footer__brand-name">{{ shop.name }}</span>
                </a>
                {%- if block.settings.text != blank -%}
                  <div class="footer__brand-tagline rte">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if block.settings.show_social -%}
                  <div class="footer__brand-social">
                    {% render 'social-icons' %}
                  </div>
                {%- endif -%}
              {%- else -%}
                {%- if block.settings.heading != blank -%}
                  <h3 class="footer__heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
                <div class="footer__text rte">{{ block.settings.text }}</div>
              {%- endif -%}

            {%- when 'social' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {% render 'social-icons' %}

            {%- when 'newsletter' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="footer__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="footer__text" style="margin-bottom: 1rem;">{{ block.settings.text }}</p>
              {%- endif -%}
              {% form 'customer', class: 'footer__newsletter-form' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                  <input
                    type="email"
                    name="contact[email]"
                    placeholder="{{ 'general.newsletter.email_placeholder' | t }}"
                    required
                    autocomplete="email"
                    aria-label="{{ 'general.newsletter.email_placeholder' | t }}"
                    class="field__input"
                    style="flex:1; min-width:180px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.2); color:#fff; padding:0.625rem 0.875rem; font-size:0.875rem; border-radius:var(--border-radius);"
                  >
                  <button type="submit" class="button" style="background:var(--color-primary); color:#fff; border-color:var(--color-primary); padding:0.625rem 1.25rem; font-size:0.8125rem; white-space:nowrap;">
                    {{ 'general.newsletter.submit' | t }}
                  </button>
                </div>
              {% endform %}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <div class="footer__copyright">
        <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</small>
      </div>
      <div class="footer__bottom-links">
        <a href="/policies/privacy-policy" class="footer__bottom-link">Privacy Policy</a>
        <a href="/policies/terms-of-service" class="footer__bottom-link">Terms of Service</a>
        <a href="/policies/refund-policy" class="footer__bottom-link">Returns</a>
      </div>
      <div class="footer__payment">
        {%- unless shop.enabled_payment_types == empty -%}
          <ul class="footer__payment-list list-unstyled" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="footer__payment-item">
                {{ type | payment_type_svg_tag: class: 'icon icon-payment' }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endunless -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text / Brand column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share store details, promotions, or brand content with your customers.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "label": "Show social icons (when used as brand column)",
          "default": false
        }
      ]
    },
    {
      "type": "social",
      "name": "Social media",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Follow Us"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Stay Connected"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Subscribe for updates on new gear and exclusive deals."
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "text",
        "settings": {
          "heading": "",
          "text": "<p>Keeping pets safe since 2015. We believe every pet deserves to travel safely.</p>",
          "show_social": true
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Shop"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Customer Care"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Learn More"
        }
      }
    ]
  }
}
{% endschema %}

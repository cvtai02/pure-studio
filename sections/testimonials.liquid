<section class="section-testimonials" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="testimonials__heading section-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="testimonials__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}
                <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <p class="testimonial-card__text">"{{ block.settings.text }}"</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">{{ block.settings.author | truncate: 1, '' | upcase }}</div>
            <div>
              <p class="testimonial-card__name" style="margin:0;">{{ block.settings.author }}</p>
              <p class="testimonial-card__verified" style="margin:0;">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                Verified Buyer
              </p>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Pet Parents Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join thousands of happy pet owners who trust us"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "My dog absolutely loves the clothes from this store! Great quality and fast shipping. Will definitely order again."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "author": "Sarah M.",
            "text": "My dog absolutely loves the clothes from this store! Great quality and fast shipping. Will definitely order again.",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "James K.",
            "text": "The cat outfits are adorable and my cats actually don't mind wearing them. Perfect fit and premium materials.",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author": "Emily R.",
            "text": "Best pet store I've found online. Amazing customer service and the products are top-notch. My pets are living their best lives!",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}

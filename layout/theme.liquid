<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {% render 'meta-tags' %}

    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {% comment %} CSS - Foundation {% endcomment %}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'component-variables.css' | asset_url | stylesheet_tag }}

    {% comment %} CSS - Components {% endcomment %}
    {{ 'component-buttons.css' | asset_url | stylesheet_tag }}
    {{ 'component-forms.css' | asset_url | stylesheet_tag }}
    {{ 'component-header.css' | asset_url | stylesheet_tag }}
    {{ 'component-hero.css' | asset_url | stylesheet_tag }}
    {{ 'component-carousel.css' | asset_url | stylesheet_tag }}
    {{ 'component-product-card.css' | asset_url | stylesheet_tag }}
    {{ 'component-product.css' | asset_url | stylesheet_tag }}
    {{ 'component-collection.css' | asset_url | stylesheet_tag }}
    {{ 'component-category-explorer.css' | asset_url | stylesheet_tag }}
    {{ 'component-cart.css' | asset_url | stylesheet_tag }}
    {{ 'component-rich-text.css' | asset_url | stylesheet_tag }}
    {{ 'component-blog.css' | asset_url | stylesheet_tag }}
    {{ 'component-search.css' | asset_url | stylesheet_tag }}
    {{ 'component-404.css' | asset_url | stylesheet_tag }}
    {{ 'component-footer.css' | asset_url | stylesheet_tag }}
    {{ 'component-pagination.css' | asset_url | stylesheet_tag }}
    {{ 'component-testimonials.css' | asset_url | stylesheet_tag }}
    {{ 'component-promise.css' | asset_url | stylesheet_tag }}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <style>
      {{ settings.type_header_font | font_face: font_display: 'swap' }}
      {{ settings.type_body_font | font_face: font_display: 'swap' }}
    </style>

    {{ content_for_header }}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    </script>
  </head>

  <body class="template-{{ template.name }}">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    {% sections 'header-group' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
